\setlength{\subrubricspace}{1pt}
\setlength{\subrubricbeforespace}{0pt}
\def\@@rubrichead#1{%
  \begin{tikzpicture}[baseline]
    % Draw a straight horizontal line
    \draw[line width=1pt, color=SwishLineColour!60!black] (0,0) -- (\@almosttextwidth,0);

    % Place the text label slightly above the line
    \node[
      font={\@rubricfont},
      inner sep=0pt,
      text ragged,
      anchor=south west,
      text depth=0.5ex,
      text height=0.5ex
    ] at (1pt,2pt) {#1};
  \end{tikzpicture}%
  \vspace\rubricspace%
}
